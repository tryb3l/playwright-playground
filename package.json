{
  "name": "playwright-playground",
  "version": "1.0.0",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npx -p @typescript/native-preview tsc --noEmit",
    "clean:port": "npx kill-port 4200 || true",
    "test:e2e": "npm run clean:port && npm run typecheck && npx playwright test",
    "test:e2e:debug": "npm run clean:port && npm run typecheck && npx playwright test --debug",
    "test:e2e:parallel": "npm run clean:port && npm run typecheck && npx playwright test --workers 4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260422.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.59.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}