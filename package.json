{
  "name": "playwright-playground",
  "version": "1.0.0",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:e2e": "npx playwright test",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:parallel": "npx playwright test --workers 4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
