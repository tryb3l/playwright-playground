    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}