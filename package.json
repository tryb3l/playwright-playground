{
  "name": "playwright-playground",
  "version": "1.0.0",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npx -p @typescript/native-preview tsc --noEmit",
    "clean:port": "npx kill-port 4200 || true",
    "test:e2e": "npm run clean:port && npm run typecheck && npx playwright test",
    "test:e2e:debug": "npm run clean:port && npm run typecheck && npx playwright test --debug",
    "test:e2e:parallel": "npm run clean:port && npm run typecheck && npx playwright test --workers 4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260307.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  }
}